<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Vacation Page Details"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs">
                <items jcr:primaryType="nt:unstructured">
                    <destination
                        cq:showOnCreate="{Boolean}false"
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Destination"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                                <items jcr:primaryType="nt:unstructured">
                                    <col1
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <city
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldLabel="City"
                                                name="./city"/>
                                            <mapLink
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldLabel="Map Link"
                                                name="./mapLink"/>
                                            <destinationType
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                fieldLabel="Destination Type"
                                                name="./destinationType">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <beach
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Beach"
                                                        value="beach"/>
                                                    <city
                                                        jcr:primaryType="nt:unstructured"
                                                        text="City"
                                                        value="city"/>
                                                    <mountain
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Mountain"
                                                        value="mountain"/>
                                                    <adventure
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Adventure"
                                                        value="adventure"/>
                                                    <cultural
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Cultural"
                                                        value="cultural"/>
                                                    <wildlife
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Wildlife"
                                                        value="wildlife"/>
                                                </items>
                                            </destinationType>
                                            <country
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                fieldLabel="Country"
                                                name="./country">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <india
                                                        jcr:primaryType="nt:unstructured"
                                                        text="India"
                                                        value="india"/>
                                                    <usa
                                                        jcr:primaryType="nt:unstructured"
                                                        text="USA"
                                                        value="usa"/>
                                                    <uk
                                                        jcr:primaryType="nt:unstructured"
                                                        text="UK"
                                                        value="uk"/>
                                                </items>
                                            </country>
                                        </items>
                                    </col1>
                                </items>
                            </columns>
                        </items>
                    </destination>
                    <experiences
                        cq:showOnCreate="{Boolean}false"
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Experiences"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                                <items jcr:primaryType="nt:unstructured">
                                    <col1
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <recommendedFor
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                fieldLabel="Recommended For"
                                                name="./recommendedFor">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <couples
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Couples"
                                                        value="couples"/>
                                                    <families
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Families"
                                                        value="families"/>
                                                    <solo
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Solo"
                                                        value="solo"/>
                                                    <groups
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Groups"
                                                        value="groups"/>
                                                    <seniors
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Seniors"
                                                        value="seniors"/>
                                                </items>
                                            </recommendedFor>
                                            <ageRestriction
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                name="./ageRestriction"
                                                text="Age Restrictions"
                                                value="true"/>
                                            <ageRestrictionDetails
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldLabel="Age Restriction Details"
                                                name="./ageRestrictionDetails"/>
                                            <wheelchairAccess
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                name="./wheelchairAccess"
                                                text="Wheelchair Access"
                                                value="true"/>
                                            <parking
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                name="./parking"
                                                text="Parking"
                                                value="true"/>
                                        </items>
                                    </col1>
                                </items>
                            </columns>
                        </items>
                    </experiences>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
